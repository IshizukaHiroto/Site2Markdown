{
  "manifest_version": 3,
  "name": "Site2Markdown",
  "version": "1.0.1",
  "description": "WebページをMarkdownに変換するChrome拡張機能",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "options/options.html",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "downloads",
    "scripting"
  ]
}
