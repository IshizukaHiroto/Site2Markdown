{
  "manifest_version": 3,
  "name": "Site2Markdown",
  "version": "1.0.0",
  "description": "Convert any webpage to Markdown for AI input or personal notes",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "options/options.html",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "vendor/Readability.js",
        "vendor/turndown.js",
        "vendor/turndown-plugin-gfm.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
